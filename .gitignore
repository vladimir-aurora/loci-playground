# NB: Upstream sources live under <project>/upstream/ as git submodules
# (see .gitmodules) — do NOT ignore those paths, they're tracked by git.

# CMake build output (any name starting with .loci-build or build)
.loci-build/
build/
build-*/
cmake-build-*/

# CMake / Ninja artifacts that can leak into the source tree
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json
*.o
*.obj
*.a
*.lib
*.elf

# IDE / editor
.vscode/
.idea/
*.code-workspace
*.swp
*~
.DS_Store
Thumbs.db
